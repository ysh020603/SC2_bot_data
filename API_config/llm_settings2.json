{
    "_comment": "备用 LLM 配置（智谱 GLM 等）。在 LLMBot.LLM_SETTINGS_FILE 或 ladder 第二参数中指定 llm_settings2.json。profile 可使用 base_url/model 或 api_url/model_name（llm_caller 均识别）。",
    "default_profile": "stage1_reasoning",
    "profiles": {
        "stage1_reasoning": {
            "_comment": "第一阶段：意图分析。",
            "api_url": "https://open.bigmodel.cn/api/paas/v4",
            "api_key": "df2af4f04d184c8cae1e0c70bbed26e0.5yVd73IGL743VEsF",
            "model_name": "glm-4.7",
            "temperature": 0.6,
            "max_tokens": 8192,
            "timeout_seconds": 60,
            "is_reasoning": true
        },
        "stage2_translation": {
            "_comment": "第二阶段：动作映射。",
            "api_url": "https://open.bigmodel.cn/api/paas/v4",
            "api_key": "df2af4f04d184c8cae1e0c70bbed26e0.5yVd73IGL743VEsF",
            "model_name": "glm-4.7",
            "temperature": 0.0,
            "max_tokens": 256,
            "timeout_seconds": 30,
            "is_reasoning": false,
            "response_format": {"type": "json_object"}
        }
    },
    "vendor_dispatch": {
        "_comment": "根据模型名子串匹配相应厂商，注入对应的 reasoning 开关。is_reasoning 由调用方控制，True => enabled，False => disabled。",
        "rules": [
            {
                "match_keywords": ["glm-4.6", "glm-4.7", "glm-4-plus", "glm-z1"],
                "vendor": "zhipuai_glm",
                "reasoning_field_path": ["extra_body", "thinking", "type"],
                "enabled_value": "enabled",
                "disabled_value": "disabled"
            },
            {
                "match_keywords": ["kimi-thinking", "kimi-k2", "moonshot-thinking"],
                "vendor": "kimi",
                "reasoning_field_path": ["extra_body", "enable_thinking"],
                "enabled_value": true,
                "disabled_value": false
            },
            {
                "match_keywords": ["deepseek"],
                "vendor": "deepseek",
                "reasoning_field_path": ["extra_body", "thinking", "type"],
                "enabled_value": "enabled",
                "disabled_value": "disabled"
            },
            {
                "match_keywords": ["qwen3", "qwen-3"],
                "vendor": "qwen",
                "reasoning_field_path": ["extra_body", "enable_thinking"],
                "enabled_value": true,
                "disabled_value": false
            }
        ],
        "fallback": {
            "_comment": "命中不到任何 vendor 时（含本地 VLLM 等通用 OpenAI 兼容服务），保留原始参数透传。",
            "vendor": "openai_compatible"
        }
    },
    "post_processing": {
        "_comment": "对模型返回的 content 做的统一清洗逻辑。",
        "strip_think_tags": true,
        "strip_reasoning_field": true
    }
}
